{
  "name": "@nerdsnipe-inc/ghl-mcp-server",
  "version": "1.2.3",
  "description": "A Model Context Protocol (MCP) server for GoHighLevel API v2 — giving any AI agent full access to your GHL location.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gohighlevel",
    "go-high-level",
    "ghl",
    "crm",
    "ai",
    "claude",
    "cursor",
    "automation"
  ],
  "homepage": "https://github.com/Nerdsnipe-Inc/ghl-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/Nerdsnipe-Inc/ghl-mcp-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NerdSnipe-Inc/ghl-mcp-server.git"
  },
  "license": "MIT",
  "author": "NerdSnipe Inc <hello@nerdsnipe.cc>",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "ghl-mcp-server": "./bin/ghl-mcp-server.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
