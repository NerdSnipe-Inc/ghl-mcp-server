# ──────────────────────────────────────────────────────────────────────────────
# GoHighLevel MCP Server — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is listed in .gitignore.

# Required: Your GHL Private Integration Token (v2)
# Get it from: GoHighLevel → Settings → Private Integrations → Create
GHL_PIT_TOKEN=your_private_integration_token_here

# Required: Your GHL Sub-Account (Location) ID
# Found in the URL when inside your sub-account:
# app.gohighlevel.com/location/<YOUR_LOCATION_ID>/dashboard
GHL_LOCATION=your_location_id_here
